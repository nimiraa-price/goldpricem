# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to GitHub

# Your Shopify store domain (without https://)
# Example: mystore.myshopify.com
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com

# Admin API token from your private app
# Get this from: Shopify Admin → Settings → Apps → Develop Apps → Your App → API Credentials
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Password to protect your admin panel
# Choose any strong password
ADMIN_PASSWORD=your-secret-password-here
